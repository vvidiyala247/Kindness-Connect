{
  "expo": {
    "name": "KindnessConnect",
    "slug": "kindnessconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kindnessconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fefaf6"
    },
    "ios": {
      "bundleIdentifier": "com.kindnessconnect.app",
      "buildNumber": "1",
      "supportsTablet": false
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow KindnessConnect to use your microphone so you can speak your message instead of typing.",
          "speechRecognitionPermission": "Allow KindnessConnect to recognise your speech so you can dictate kindness messages hands-free."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
